{
  "expo": {
    "name": "Neuroformance EA",
    "slug": "neuroformance-ea",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/neuroformance-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/neuroformance-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/neuroformance-icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/neuroformance-adaptive-icon.png",
        "backgroundColor": "#020617"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/neuroformance-icon.png",
      "name": "Neuroformance EA",
      "shortName": "Neuroformance",
      "themeColor": "#8B5CF6",
      "backgroundColor": "#020617",
      "description": "Sistema de prontidão, reflexo e performance para acompanhamento de sono, recuperação e treino."
    },
    "scheme": "neuroformance-ea"
  }
}
