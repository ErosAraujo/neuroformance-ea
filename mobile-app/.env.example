# URL base da API do Neuroformance EA. Inclua /api no final.

# PC local/navegador no mesmo computador do backend:
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Alternativa para teste local no navegador do PC:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000/api

# Celular físico na mesma rede Wi-Fi do PC onde o backend roda:
# EXPO_PUBLIC_API_URL=http://192.168.0.10:3000/api

# Produção/PWA publicado:
# EXPO_PUBLIC_API_URL=https://sono-app-backend.onrender.com/api
