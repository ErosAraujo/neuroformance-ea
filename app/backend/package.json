{
  "name": "neuroformance-ea-backend",
  "version": "1.0.0",
  "main": "build/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:deploy": "npx prisma migrate deploy",
    "seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "test": "ts-node tests/score.test.ts && ts-node tests/contracts.test.ts && ts-node tests/quality.test.ts && ts-node tests/teacherDashboard.test.ts && ts-node tests/insightService.test.ts",
    "typecheck": "tsc --noEmit",
    "build:with-prisma": "npm run prisma:generate && npm run build",
    "prisma:validate": "npx prisma validate",
    "prisma:migrate:status": "npx prisma migrate status"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.8.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "@types/web-push": "^3.6.4"
  }
}
