# Arquivo de exemplo de variáveis de ambiente para o backend do Neuroformance EA

# URL de conexão do banco PostgreSQL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# Chave secreta usada para assinar tokens JWT. Use uma string longa e única em produção.
JWT_SECRET=troque_por_uma_chave_grande_e_secreta

# Lista de origens permitidas separadas por vírgula.
# Ajuste para as URLs reais onde você publicar o painel do professor e o app do aluno.
CORS_ORIGIN=https://painel.seudominio.com,https://app-aluno.seudominio.com

# Porta do servidor. No Render, normalmente o próprio Render injeta PORT.
PORT=3000

# Opcional: dados demo para npm run seed.
# Por padrão o seed preserva dados existentes. Use RESET_DEMO=true apenas quando quiser recriar registros demo.
RESET_DEMO=false
SEED_TEACHER_NAME=Eros Araújo
SEED_TEACHER_EMAIL=erosaraujopersonal@gmail.com
SEED_TEACHER_PASSWORD=Xuxa123
SEED_STUDENT_PASSWORD=123456

# Obrigatório em produção para permitir cadastro público de professores.
ADMIN_CREATE_TEACHER_SECRET=troque_por_um_segredo_de_admin

# Rate limit configurável.
# Em desenvolvimento, os limites padrão são altos para não travar testes locais.
# Em produção, mantenha ligado para proteção básica contra abuso.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=900
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=30
# Para teste local emergencial, pode usar true. Não use true em produção.
DISABLE_RATE_LIMIT=false

# Web Push/PWA para lembrete diário real
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:professor@seudominio.com
PUSH_REMINDER_INTERVAL_MS=300000
