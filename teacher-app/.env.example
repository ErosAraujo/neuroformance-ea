# Local recomendado
# Deixe como /api para o Vite fazer proxy para http://localhost:3000/api.
# Isso evita CORS/Network Error em localhost, preview e teste pelo celular na mesma rede.
VITE_API_URL=/api

# Se precisar mudar o backend local usado pelo proxy:
VITE_BACKEND_TARGET=http://localhost:3000

# Produção: use a URL HTTPS real do backend, incluindo /api.
# VITE_API_URL=https://seu-backend.onrender.com/api

# URL pública do app do aluno. Se ficar vazio, o teacher-app apenas orienta o aluno a usar o app mobile/PWA correto.
VITE_STUDENT_APP_URL=
